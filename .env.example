# Macro Analyzer — Environment Variables
# Copia questo file in .env e compila i valori

# =========================================================
# PostgreSQL (usato sia localmente che in docker-compose)
# =========================================================
POSTGRES_DB=macro_analyzer
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# DATABASE_URL viene composto automaticamente dentro docker-compose
# dalle tre variabili qui sopra. Per sviluppo locale (senza docker) usa:
DATABASE_URL=postgresql+psycopg://postgres:changeme@localhost:5432/macro_analyzer

# =========================================================
# API Keys
# =========================================================

# FRED (gratis: https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_api_key_here

# Google Gemini 2.5 Flash (spiegazioni narrative dedollarizzazione)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq (news scoring)
GROQ_API_KEY=your_groq_api_key_here

# NewsAPI (opzionale, fallback RSS)
NEWSAPI_KEY=

# =========================================================
# Scheduler (ora UTC per il refresh giornaliero)
# =========================================================
# Default 06:00 UTC. Per mezzanotte UTC: HOUR=0 MINUTE=0
# In Italia:  0 UTC = 01:00 invernale / 02:00 estivo
SCHEDULER_HOUR=6
SCHEDULER_MINUTE=0
TZ=UTC

# =========================================================
# Docker-only
# =========================================================
# Porta pubblica sulla quale nginx esporrà l'app.
# In locale lascia 80. Su VPS dietro reverse-proxy tipo Caddy/Traefik metti 8080.
FRONTEND_PORT=80
